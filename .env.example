# Optional: override default SQLite database location.
# If unset, app uses default path resolution from storage.DefaultDBPath().
DREAMS_DB_PATH=

# Optional: preferred external editor for :e command in TUI.
# Falls back to VISUAL then EDITOR.
DREAMS_EDITOR=

# Optional: Night priming AI source configuration (OpenAI-compatible API).
# Example:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=your_api_key_here
# AI_MODEL=gpt-4o-mini
# AI_MODEL_FALLBACK=gpt-4o
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_MODEL_FALLBACK=
